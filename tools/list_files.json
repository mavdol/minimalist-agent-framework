{
    "name": "list_files",
    "description": "List files in a directory.",
    "parameters": {
        "type": "object",
        "properties": {
            "path": {
                "type": "string",
                "description": "The path to the directory to list."
            }
        },
        "required": ["path"]
    },
    "sandbox": {
        "compute": "LOW",
        "ram": "64MB",
        "timeout": "10s",
        "max_retries": 1,
        "allowed_files": [{
            "path": ".",
            "mode": "read-only"
        }],
        "allowed_hosts": [],
        "env_variables": []
    }
}
