{
    "name": "execute_code",
    "description": "Execute Pure Python code. Don't import external libraries. Use this for any task non listed task. Prefer this over asking for more tools.",
    "parameters": {
        "type": "object",
        "properties": {
            "code": {
                "type": "string",
                "description": "The Python code to execute."
            }
        },
        "required": ["code"]
    },
    "sandbox": {
        "compute": "MEDIUM",
        "ram": "256MB",
        "timeout": "30s",
        "max_retries": 1,
        "allowed_files": [{
            "path": ".",
            "mode": "read-only"
        }],
        "allowed_hosts": [],
        "env_variables": []
    }
}
